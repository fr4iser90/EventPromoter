{
  "dedupe": {
    "enabled": true,
    "line_window": 2
  },
  "codeql": {
    "accepted_findings": [
      {
        "rule_id": "js/path-injection",
        "path_regex": "(?:.*/)?backend/src/(controllers/fileController|controllers/parsingController|services/historyService|services/eventService|services/publishTrackingService|services/parsing/contentParsingService|services/telemetryService|utils/fileUtils|utils/translationLoader)\\.ts$",
        "message_regex": "This path depends on a .*user-provided value",
        "reason": "Paths are constrained by PathConfig and security helpers (resolveSafePath/sanitizers) with boundary checks; scanner cannot fully infer custom guards."
      },
      {
        "rule_id": "js/missing-rate-limiting",
        "path_regex": "(?:.*/)?backend/src/routes/(auth|files|parsing|index)\\.ts$",
        "message_regex": "not rate-limited",
        "reason": "Routes use explicit rate-limit middleware and auth middleware; static analysis misses middleware chaining across router layers."
      },
      {
        "rule_id": "js/insecure-helmet-configuration",
        "path_regex": "(?:.*/)?backend/src/middleware/helmet\\.ts$",
        "message_regex": "contentSecurityPolicy.*false",
        "reason": "CSP is intentionally disabled only in development; production config enables CSP directives."
      },
      {
        "rule_id": "js/request-forgery",
        "path_regex": "(?:.*/)?backend/src/services/telemetryService\\.ts$",
        "message_regex": "URL.*user-provided value",
        "reason": "Destination hosts are fixed provider APIs; user input affects only identifiers/parameters, not protocol/host."
      },
      {
        "rule_id": "js/double-escaping",
        "path_regex": "(?:.*/)?backend/src/(platforms/email/publishers/api/utils/htmlToText|platforms/email/publishers/playwright/utils/htmlToText|services/templateMappingService)\\.ts$",
        "message_regex": "double-unescaped",
        "reason": "Helpers are best-effort text conversion utilities for preview/content mapping, not primary trust-boundary sanitizers."
      },
      {
        "rule_id": "js/bad-tag-filter",
        "path_regex": "(?:.*/)?backend/src/(platforms/email/publishers/api/utils/htmlToText|platforms/email/publishers/playwright/utils/htmlToText|services/templateMappingService)\\.ts$",
        "message_regex": "regular expression does not match script end tags",
        "reason": "Regexes are used for formatting cleanup in helper paths; not relied upon as complete XSS sanitizers."
      },
      {
        "rule_id": "js/incomplete-multi-character-sanitization",
        "path_regex": "(?:.*/)?backend/src/(platforms/email/publishers/api/utils/htmlToText|platforms/email/publishers/playwright/utils/htmlToText|platforms/email/services/emailService|platforms/email/services/previewService|services/templateMappingService)\\.ts$",
        "message_regex": "This string may still contain",
        "reason": "These findings are in content transformation/preview helper code, not in direct untrusted script execution sinks."
      },
      {
        "rule_id": "js/incomplete-multi-character-sanitization",
        "path_regex": "(?:.*/)?frontend/src/shared/components/ui/HelperIcon\\.tsx$",
        "message_regex": "This string may still contain",
        "reason": "Markdown rendering path has been hardened; residual scanner output here is accepted as conservative false positive."
      }
    ]
  },
  "gitleaks": {
    "accepted_findings": [
      {
        "rule_id": "linkedin-client-id",
        "file_regex": "(?:.*/)?backend/src/platforms/linkedin/(index\\.ts|schema/index\\.ts|schema/settings\\.ts|service\\.ts)$",
        "description_regex": ".*LinkedIn Client ID.*",
        "reason": "Matched values are LinkedIn platform identifiers/schema metadata, not real credentials."
      },
      {
        "rule_id": "linkedin-client-secret",
        "file_regex": "(?:.*/)?backend/src/platforms/linkedin/tokens\\.ts$",
        "description_regex": ".*LinkedIn Client secret.*",
        "reason": "Flagged token-related identifier names in implementation code, not embedded secrets."
      },
      {
        "rule_id": "generic-api-key",
        "file_regex": "(?:.*/)?backend/src/utils/SECRETS_ENCRYPTION\\.md$",
        "description_regex": ".*Generic API Key.*",
        "reason": "Matches documentation examples in security docs; no active production secret is committed."
      }
    ]
  },
  "semgrep": {
    "accepted_findings": [
      {
        "rule_id": "javascript.lang.security.audit.path-traversal.path-join-resolve-traversal.path-join-resolve-traversal",
        "path_regex": "(?:.*/)?(backend/src/(controllers/fileController|controllers/parsingController|middleware/upload|platforms/email/publishers/api/utils/resolveAttachments|platforms/email/services/previewService|platforms/(instagram|linkedin|twitter)/translations|services/eventService|services/helperService|services/historyService|services/parsing/contentParsingService|services/publishTrackingService|services/publishingService|services/telemetryService|utils/pathConfig|utils/platformDataUtils|utils/platformDiscovery|utils/securityUtils|utils/translationLoader)\\.ts|frontend/scripts/(extract-i18n-keys|validate-i18n)\\.js|scripts/i18n-audit\\.js|workflows/build-all\\.js|workflows/multiplatform-publisher/build\\.js|workflows/multiplatform-publisher/config/platforms/index\\.js)$",
        "message_regex": ".*path\\.join.*path\\.resolve.*",
        "reason": "Paths are constrained by trusted base directories, explicit sanitization helpers, and trusted build contexts; scanner does not fully model these guards."
      },
      {
        "rule_id": "javascript.lang.security.audit.unsafe-formatstring.unsafe-formatstring",
        "path_regex": "(?:.*/)?(frontend/src/features/platform/components/PlatformEditor\\.tsx|workflows/build-all\\.js|workflows/multiplatform-publisher/config/platforms/index\\.js|workflows/multiplatform-publisher/platforms/hybrid-poster\\.js|workflows/multiplatform-publisher/platforms/playwright/core\\.js)$",
        "message_regex": ".*format specifier.*",
        "reason": "Findings are logging statements only; no attacker-controlled format string reaches privileged sinks."
      },
      {
        "rule_id": "generic.nginx.security.possible-h2c-smuggling.possible-nginx-h2c-smuggling",
        "path_regex": "(?:.*/)?frontend/nginx\\.conf$",
        "message_regex": ".*H2C smuggling.*",
        "reason": "Deployment is behind controlled reverse proxy with explicit protocol handling; Semgrep pattern is conservative."
      },
      {
        "rule_id": "generic.nginx.security.request-host-used.request-host-used",
        "path_regex": "(?:.*/)?frontend/nginx\\.conf$",
        "message_regex": ".*\\$http_host.*\\$host.*",
        "reason": "Host handling is constrained by ingress/proxy config; direct untrusted host routing is not used as trust decision input."
      },
      {
        "rule_id": "javascript.express.security.audit.express-path-join-resolve-traversal.express-path-join-resolve-traversal",
        "path_regex": "(?:.*/)?backend/src/controllers/fileController\\.ts$",
        "message_regex": ".*outside of the destination.*",
        "reason": "File listing path is now resolved via resolveSafePath against event directory boundaries; static rule may still report conservative traversal risk."
      },
      {
        "rule_id": "javascript.lang.security.audit.detect-non-literal-regexp.detect-non-literal-regexp",
        "path_regex": "(?:.*/)?(backend/src/utils/safeRegex\\.ts|frontend/src/shared/utils/safeRegex\\.ts|workflows/multiplatform-publisher/scripts/email-merge-attachments\\.js)$",
        "message_regex": ".*RegExp\\(\\).*",
        "reason": "Dynamic regex usage is intentionally constrained by strict input length/charset/escaping guards and limited to validation/HTML replacement helper flows."
      },
      {
        "rule_id": "javascript.lang.security.audit.prototype-pollution.prototype-pollution-loop.prototype-pollution-loop",
        "path_regex": "(?:.*/)?(backend/src/utils/tokenResolver\\.ts|frontend/src/features/platform/components/Panel\\.tsx|frontend/src/shared/components/EditModal\\.tsx)$",
        "message_regex": ".*prototype polluting function.*",
        "reason": "Dynamic key traversal applies explicit key denylist and own-property checks before access, preventing prototype chain mutation paths."
      },
      {
        "rule_id": "javascript.playwright.security.audit.playwright-goto-injection.playwright-goto-injection",
        "path_regex": "(?:.*/)?workflows/multiplatform-publisher/platforms/playwright/core\\.js$",
        "message_regex": ".*goto method.*SSRF.*",
        "reason": "Navigation URLs are validated with protocol allowlist and host allowlist prior to page.goto; remaining hit is scanner conservatism on wrapper flow."
      }
    ]
  }
}
